# Normalize line endings: LF in the repo for all text, so builds are identical
# across Windows/macOS/Linux and diffs stay clean.
* text=auto eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
