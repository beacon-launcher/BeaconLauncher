{
  "name": "beacon-launcher",
  "productName": "Beacon Launcher",
  "version": "0.3.0",
  "description": "Beacon — a dead-simple, open-source, offline Minecraft launcher (Electron + React).",
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "Beacon Launcher",
    "email": "beacon-launcher@users.noreply.github.com",
    "url": "https://github.com/beacon-launcher"
  },
  "homepage": "https://github.com/beacon-launcher/BeaconLauncher",
  "repository": {
    "type": "git",
    "url": "https://github.com/beacon-launcher/BeaconLauncher.git"
  },
  "bugs": {
    "url": "https://github.com/beacon-launcher/BeaconLauncher/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "sync:translations": "node scripts/sync-translations.mjs",
    "build": "npm run sync:translations && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "pack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "release": "npm run build && electron-builder --win --mac --linux --publish always"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "@xmcl/unzip": "^2.1.2",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.5",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "undici": "^6.21.0"
  },
  "overrides": {
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}
